{
  "name": "rox",
  "version": "0.0.0-local",
  "bin": "index.js",
  "dependencies": {
    "roxify": "^1.5.10"
  },
  "devDependencies": {
    "esbuild": "^0.18.11",
    "pkg": "^5.8.1"
  },
  "scripts": {
    "build:exe": "cd /home/yohan/roxify && cargo build --release --bin roxify_native --target x86_64-pc-windows-gnu && npm run build:pkg && cd - && node ./scripts/postbuild.js",
    "postinstall": "node ./scripts/fix-cli-progress-presets.js",
    "postbuild:exe": "node ./scripts/postbuild.js",
    "buildAndSetup": "bash ./scripts/build-and-setup.sh",
    "buildReleasesAndSetup": "bash ./scripts/build-releases-and-setup.sh",
    "publishReleases": "bash ./scripts/publish-releases.sh",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true}); require('fs').rmSync('build', {recursive:true, force:true});\""
  },
  "pkg": {
    "assets": [
      "node_modules/roxify/**/*",
      "build/**/*"
    ]
  }
}
