{
  "name": "rox",
  "version": "0.0.0-local",
  "bin": "index.js",
  "dependencies": {
    "roxify": "latest"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "esbuild": "^0.18.11"
  },
  "scripts": {
    "bundle:rox": "node ./node_modules/esbuild/bin/esbuild node_modules/roxify/dist/cli.js --bundle --platform=node --format=cjs --external:*.node --external:@img/* --outfile=build/rox-bundle.cjs",
    "build:exe": "node ./node_modules/esbuild/bin/esbuild node_modules/roxify/dist/cli.js --bundle --platform=node --format=cjs --external:*.node --external:@img/* --outfile=build/rox-bundle.cjs && node ./scripts/postbuild.js",
    "postinstall": "node ./scripts/fix-cli-progress-presets.js",
    "postbuild:exe": "node ./scripts/postbuild.js"
  },
  "pkg": {
    "assets": [
      "node_modules/roxify/**/*",
      "build/**/*",
      "node_modules/@mongodb-js/zstd/build/**/*",
      "node_modules/sharp/vendor/**/*",
      "node_modules/sharp/build/Release/**/*"
    ]
  }
}
