{
  "name": "roxify",
  "version": "1.2.7",
  "description": "Encode binary data into PNG images with Zstd compression and decode them back. Supports CLI and programmatic API (Node.js ESM).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rox": "dist/cli.js",
    "roxify": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check-publish": "node ../scripts/check-publish.js roxify",
    "cli": "node dist/cli.js",
    "test": "npm run build && node test/pack.test.js && node test/screenshot.test.js && node test/list.test.js && node test/minpng.test.js && node test/optimize.test.js"
  },
  "keywords": [
    "steganography",
    "png",
    "zstd",
    "compression",
    "encryption",
    "encode",
    "decode",
    "cli",
    "nodejs",
    "esm",
    "data-embedding",
    "file-archive",
    "lossless",
    "aes-gcm",
    "binary-data"
  ],
  "author": "RoxCompressor",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mongodb-js/zstd": "^2.0.1",
    "fflate": "^0.7.4",
    "lzma-purejs": "^0.9.3",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "sharp": "^0.34.5",
    "cli-progress": "^3.9.1"
  },
  "optionalDependencies": {
    "zopflipng-bin": "^1.0.1"
  },
  "overrides": {
    "graceful-fs": "^4.2.10"
  },
  "devDependencies": {
    "typescript": "^4.9.5",
    "@types/cli-progress": "^3.9.0"
  }
}
