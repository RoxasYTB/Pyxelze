<Project Sdk="Microsoft.NET.Sdk">
      <PropertyGroup>
            <OutputType>WinExe</OutputType>
            <TargetFramework>net7.0-windows</TargetFramework>
            <UseWindowsForms>true</UseWindowsForms>
            <ImplicitUsings>enable</ImplicitUsings>
            <Nullable>enable</Nullable>
            <ApplicationIcon>appIcon.ico</ApplicationIcon>
            <!-- Disable SDK-generated assembly attributes to avoid duplicate attribute issues -->
            <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
            <GenerateAssemblyCompanyAttribute>false</GenerateAssemblyCompanyAttribute>
            <GenerateAssemblyConfigurationAttribute>false</GenerateAssemblyConfigurationAttribute>
            <GenerateAssemblyFileVersionAttribute>false</GenerateAssemblyFileVersionAttribute>
            <GenerateAssemblyInformationalVersionAttribute>false</GenerateAssemblyInformationalVersionAttribute>
            <GenerateAssemblyProductAttribute>false</GenerateAssemblyProductAttribute>
            <GenerateAssemblyTitleAttribute>false</GenerateAssemblyTitleAttribute>
            <GenerateAssemblyVersionAttribute>false</GenerateAssemblyVersionAttribute>
            <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>

      </PropertyGroup>

      <ItemGroup>
            <None Update="appIcon.ico">
                  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            </None>
      </ItemGroup>
      <ItemGroup>
            <!-- Exclude test project sources from main project wildcard includes -->
            <Compile Remove="dnd_test\**\*.cs" />
      </ItemGroup>
      <Target Name="BuildRoxifyCli" BeforeTargets="BeforeBuild">
            <Exec Command="where node" IgnoreExitCode="true" />
            <Exec Command="npm ci" WorkingDirectory="$(ProjectDir)tools\roxify"
                  ContinueOnError="true" />
            <Exec Command="npm run build:exe" WorkingDirectory="$(ProjectDir)tools\roxify"
                  ContinueOnError="true" />
            <!-- Copy the entire roxify dist into the project's output so users without Node can use
            the CLI -->
            <ItemGroup>
                  <RoxifyDistFiles Include="$(ProjectDir)tools\roxify\dist\**\*.*"
                        Condition="Exists('$(ProjectDir)tools\roxify\dist')" />
            </ItemGroup>
            <Copy SourceFiles="@(RoxifyDistFiles)"
                  Condition="Exists('$(ProjectDir)tools\roxify\dist')"
                  DestinationFiles="@(RoxifyDistFiles->'$(OutDir)tools\roxify\%(RecursiveDir)%(Filename)%(Extension)')" />
      </Target>
</Project>